#!/usr/bin/env bash
set -euo pipefail

MY="aba-hadi"

if [ "$#" -ne 2 ]; then
    echo "Usage: $0 /public/filename ownername"
    exit 1
fi

FILE="$1"
OWNER="$2"

if [ ! -e "$FILE" ]; then
    echo "Error: file does not exist: $FILE"
    exit 1
fi

if [[ "$OWNER" != "jack" && "$OWNER" != "jill" && "$OWNER" != "tay" ]]; then
    echo "Error: owner must be jack, jill, or tay"
    exit 1
fi

echo "Applying Example 2 ACLs to $FILE (owner: $OWNER)"

# Clear old ACLs
setfacl -b "$FILE"
setfacl -k "$FILE"

# Keep base mode restrictive
chmod 600 "$FILE"

# Base ACLs
setfacl -m u:$OWNER:rw- "$FILE"
setfacl -m u:$MY:rw- "$FILE"
setfacl -m g::--- "$FILE"
setfacl -m o::--- "$FILE"
setfacl -m m:rw- "$FILE"

case "$OWNER" in
    jack)
        # Jill may write only, not read
        setfacl -m u:jill:-w- "$FILE"
        # Tay blocked
        setfacl -m u:tay:--- "$FILE"
        ;;
    jill)
        # Jack may write only, not read
        setfacl -m u:jack:-w- "$FILE"
        # Tay blocked
        setfacl -m u:tay:--- "$FILE"
        ;;
    tay)
        # Jack and Jill blocked
        setfacl -m u:jack:--- "$FILE"
        setfacl -m u:jill:--- "$FILE"
        ;;
esac

echo "Done. Current ACLs:"
getfacl "$FILE"
