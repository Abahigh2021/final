#!/usr/bin/env bash
set -euo pipefail

MY="aba-hadi"

if [ "$#" -ne 2 ]; then
  echo "Usage: $0 /public/filename ownername"
  echo "Apply Example 2 ACLs to a file on the gateway."
  exit 1
fi

FILE="$1"
OWNER="$2"

if [ ! -e "$FILE" ]; then
  echo "Error: file does not exist: $FILE"
  exit 1
fi

if [ "$OWNER" != "jack" ] && [ "$OWNER" != "jill" ] && [ "$OWNER" != "tay" ]; then
  echo "Error: owner must be jack, jill, or tay"
  exit 1
fi

echo "Applying Example 2 ACLs to $FILE (owner: $OWNER)"

# Reset file
chown "$OWNER:$OWNER" "$FILE"
chmod 600 "$FILE"
setfacl -b "$FILE"

# Base ACLs
setfacl -m u:$OWNER:rw- "$FILE"
setfacl -m u:$MY:rw- "$FILE"     # MySeneca user has rw- on ALL files
setfacl -m g::--- "$FILE"
setfacl -m o:--- "$FILE"

case "$OWNER" in

  jack)
    # Jill can write but not read
    setfacl -m u:jill:-w- "$FILE"
    # Tay cannot access
    setfacl -m u:tay:--- "$FILE"
    ;;

  jill)
    # Jack can write but not read
    setfacl -m u:jack:-w- "$FILE"
    # Tay cannot access
    setfacl -m u:tay:--- "$FILE"
    ;;

  tay)
    # Jack cannot access Tay
    setfacl -m u:jack:--- "$FILE"
    # Jill cannot access Tay
    setfacl -m u:jill:--- "$FILE"
    ;;
esac

echo "Example 2 ACLs applied."
getfacl "$FILE"
