#!/usr/bin/env bash
set -euo pipefail

MY="aba-hadi"

if [ "$#" -ne 2 ]; then
  echo "Usage: $0 /public/filename ownername"
  exit 1
fi

FILE="$1"
OWNER="$2"

if [ ! -e "$FILE" ]; then
  echo "Error: file does not exist: $FILE"
  exit 1
fi

if [[ "$OWNER" != "jack" && "$OWNER" != "jill" && "$OWNER" != "tay" ]]; then
  echo "Error: owner must be jack, jill, or tay"
  exit 1
fi

echo "Applying Example 2 ACLs to $FILE (Owner: $OWNER)"

# DO NOT CHANGE PERMISSIONS HERE — Example 2 REQUIRES 622
# The user must set chmod 622 BEFORE running this script.
# We only apply ACLs.

# Clear ACLs
setfacl -b "$FILE"
setfacl -k "$FILE"

# Base ACLs
setfacl -m u:$OWNER:rw- "$FILE"
setfacl -m u:$MY:rw- "$FILE"
setfacl -m g::--- "$FILE"
setfacl -m o::--- "$FILE"
setfacl -m m:rw- "$FILE"

case "$OWNER" in
  jack)
    setfacl -m u:jill:-w- "$FILE"
    setfacl -m u:tay:--- "$FILE"
    ;;
  jill)
    setfacl -m u:jack:-w- "$FILE"
    setfacl -m u:tay:--- "$FILE"
    ;;
  tay)
    setfacl -m u:jack:--- "$FILE"
    setfacl -m u:jill:--- "$FILE"
    ;;
esac

echo "--- ACLs applied successfully ---"
getfacl "$FILE"
