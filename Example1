#!/usr/bin/env bash
set -euo pipefail

MY="aba-hadi"

if [ "$#" -ne 2 ]; then
  echo "Usage: $0 /public/filename ownername"
  exit 1
fi

FILE="$1"
OWNER="$2"

if [ ! -e "$FILE" ]; then
  echo "Error: file does not exist: $FILE"
  exit 1
fi

if [ "$OWNER" != "jack" ] && [ "$OWNER" != "jill" ]; then
  echo "Error: owner must be jack or jill for Example 1"
  exit 1
fi

if [ "$OWNER" = "jack" ]; then
  OTHER="jill"
else
  OTHER="jack"
fi

echo "Applying Example 1 ACLs to $FILE (owner: $OWNER)"

chown "$OWNER:$OWNER" "$FILE"
chmod 600 "$FILE"
setfacl -b "$FILE"

setfacl -m u:$OTHER:r-- "$FILE"
setfacl -m u:tay:--- "$FILE"
setfacl -m u:$MY:rw- "$FILE"
setfacl -m g::--- "$FILE"
setfacl -m o:--- "$FILE"
setfacl -m m:rw- "$FILE"

echo "Example 1 ACLs applied."
getfacl "$FILE"
