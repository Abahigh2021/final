#!/usr/bin/env bash
set -euo pipefail

MY="aba-hadi"

if [ "$#" -ne 2 ]; then
  echo "Usage: $0 /public/filename ownername"
  exit 1
fi

FILE="$1"
OWNER="$2"

if [ ! -e "$FILE" ]; then
  echo "Error: file does not exist: $FILE"
  exit 1
fi

if [ "$OWNER" != "jack" ] && [ "$OWNER" != "jill" ] && [ "$OWNER" != "tay" ]; then
  echo "Error: owner must be jack, jill, or tay"
  exit 1
fi

echo "Applying Example 1 ACLs to $FILE (owner: $OWNER)"

# Reset file
chown "$OWNER:$OWNER" "$FILE"
chmod 600 "$FILE"
setfacl -b "$FILE"

# Base ACLs
setfacl -m u:$OWNER:rw- "$FILE"
setfacl -m u:$MY:rwx "$FILE"
setfacl -m g::--- "$FILE"
setfacl -m o:--- "$FILE"

case "$OWNER" in
  jack)
    # jill can read jack
    setfacl -m u:jill:r-- "$FILE"
    # jack cannot read tay, so tay cannot read jack
    setfacl -m u:tay:--- "$FILE"
    ;;
  jill)
    # jack can read jill
    setfacl -m u:jack:r-- "$FILE"
    # tay cannot read jill
    setfacl -m u:tay:--- "$FILE"
    ;;
  tay)
    # jack cannot read tay
    setfacl -m u:jack:--- "$FILE"
    # jill cannot read tay
    setfacl -m u:jill:--- "$FILE"
    ;;
esac

echo "Example 1 ACLs applied."
getfacl "$FILE"
